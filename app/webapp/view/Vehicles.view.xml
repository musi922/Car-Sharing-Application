<mvc:View
    controllerName="com.moyo.demo.caplugins.controller.Vehicles"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
>
    <f:DynamicPage id="vehiclesPage" headerExpanded="true" fitContent="true" class="sapUiNoContentPadding">
        <f:title>
            <f:DynamicPageTitle>
                <f:navigationActions>
                    <Button icon="sap-icon://nav-back" press=".onNavBack" type="Transparent" tooltip="Go Back" />
                </f:navigationActions>
                <f:heading>
                    <HBox alignItems="Center">
                        <Title text="Moyotech" class="sapUiSmallMarginEnd" />
                        <Link text="Home" press=".onNavHome" class="sapUiSmallMarginEnd" />
                        <Link text="Vehicles" class="sapUiSmallMarginEnd" />
                        <Link text="Details" class="sapUiSmallMarginEnd" />
                    </HBox>
                </f:heading>
                <f:actions>
                    <Button icon="sap-icon://phone" text="+996 247-1680" type="Transparent" />
                    <Button icon="sap-icon://customer" type="Transparent" />
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <VBox class="sapUiSmallMarginBegin sapUiSmallMarginTopBottom">
                    <SearchField
                        placeholder="Filter by brand or model..."
                        search=".onSearch"
                        width="400px"
                        class="sapUiSmallMarginBottom"
                    />
                    <SegmentedButton selectedKey="all" selectionChange=".onFilterType">
                        <items>
                            <SegmentedButtonItem key="all" text="All Vehicles" />
                            <SegmentedButtonItem key="Sedan" text="Sedan" />
                            <SegmentedButtonItem key="SUV" text="SUV" />
                            <SegmentedButtonItem key="Truck" text="Pickup" />
                        </items>
                    </SegmentedButton>
                </VBox>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <VBox class="sapUiMediumMargin">
                <f:GridContainer
                    id="vehiclesGrid"
                    items="{path: '/Cars'}"
                    width="100%"
                >
                    <f:layout>
                        <f:GridContainerSettings
                            minColumnSize="200px"
                            maxColumnSize="400px"
                            gap="1rem"
                        />
                    </f:layout>
                    <f:items>
                        <Panel
                            width="100%"
                            backgroundDesign="Solid"
                            class="sapUiNoContentPadding"
                        >
                            <VBox width="100%">

                                <!-- Full-bleed image -->
                                <Image
                                    src="{imageURL}"
                                    width="100%"
                                    height="180px"
                                    mode="Background"
                                    backgroundSize="cover"
                                    backgroundPosition="center"
                                />

                                <!-- Card body -->
                                <VBox class="sapUiSmallMargin">

                                    <!-- Title row: name left, price right -->
                                    <HBox justifyContent="SpaceBetween" width="100%" class="sapUiTinyMarginBottom">
                                        <VBox>
                                            <Title text="{brand} {model}" level="H4" wrapping="true" />
                                        </VBox>
                                        <VBox alignItems="End">
                                            <ObjectNumber
                                                number="{pricePerDay}"
                                                numberUnit="$ / day"
                                                emphasized="true"
                                            />
                                        </VBox>
                                    </HBox>

                                    <!-- Status badge -->
                                    <ObjectStatus
                                        text="{status}"
                                        state="{= ${status} === 'Available' ? 'Success' : 'Error' }"
                                        inverted="true"
                                        class="sapUiSmallMarginBottom"
                                    />

                                    <!-- Divider -->
                                    <core:HTML content="&lt;div style='border-top:1px solid #e5e5e5;margin-bottom:8px'/&gt;" />

                                    <!-- Year | Fuel -->
                                    <HBox justifyContent="SpaceBetween" width="100%" class="sapUiTinyMarginBottom">
                                        <VBox>
                                            <Label text="Year" design="Bold" />
                                            <Text text="{year}" />
                                        </VBox>
                                        <VBox alignItems="End">
                                            <Label text="Fuel" design="Bold" />
                                            <Text text="{fuelType}" />
                                        </VBox>
                                    </HBox>

                                    <!-- Transmission | Seats -->
                                    <HBox justifyContent="SpaceBetween" width="100%" class="sapUiSmallMarginBottom">
                                        <VBox>
                                            <Label text="Transmission" design="Bold" />
                                            <Text text="{transmission}" />
                                        </VBox>
                                        <VBox alignItems="End">
                                            <Label text="Seats" design="Bold" />
                                            <Text text="{seats}" />
                                        </VBox>
                                    </HBox>

                                    <Button
                                        text="View Details"
                                        type="Emphasized"
                                        width="100%"
                                        press=".onViewDetails"
                                        icon="sap-icon://detail-view"
                                    />
                                </VBox>
                            </VBox>
                        </Panel>
                    </f:items>
                </f:GridContainer>
            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>