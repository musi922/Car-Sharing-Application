<mvc:View
    controllerName="com.moyo.demo.caplugins.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:form="sap.ui.layout.form"
>
    <f:DynamicPage
        id="homePage"
        headerExpanded="true"
        showFooter="false"
        fitContent="true"
        class="sapUiNoContentPadding"
    >
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <HBox alignItems="Center">
                        <Title text="Moyotech" class="sapUiSmallMarginEnd" />
                        <Link text="Home" press=".onNavHome" class="sapUiSmallMarginEnd" />
                        <Link text="Vehicles" press=".onNavVehicles" class="sapUiSmallMarginEnd" />
                        <Link text="Details" class="sapUiSmallMarginEnd" />
                    </HBox>
                </f:heading>
                <f:actions>
                    <Button icon="sap-icon://phone" text="+996 247-1680" type="Transparent" />
                    <Button icon="sap-icon://customer" type="Transparent" />
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <HBox
                    justifyContent="Start"
                    alignItems="Center"
                    wrap="Wrap"
                    class="sapUiSmallMarginBegin sapUiTinyMarginTopBottom"
                >
                    <GenericTile
                        header="Fleet Size"
                        subheader="Luxury &amp; Economy"
                        press="onTilePress"
                        sizeBehavior="Small"
                        frameType="TwoByOne"
                        class="sapUiSmallMarginEnd"
                    >
                        <TileContent>
                            <NumericContent value="250+" valueColor="Good" indicator="Up" withMargin="false" />
                        </TileContent>
                    </GenericTile>
                    <GenericTile
                        header="Locations"
                        subheader="Across the Country"
                        press="onTilePress"
                        sizeBehavior="Small"
                        frameType="TwoByOne"
                        class="sapUiSmallMarginEnd"
                    >
                        <TileContent>
                            <NumericContent value="45" valueColor="Neutral" withMargin="false" />
                        </TileContent>
                    </GenericTile>
                    <GenericTile
                        header="Reviews"
                        subheader="Customer Satisfaction"
                        press="onTilePress"
                        sizeBehavior="Small"
                        frameType="TwoByOne"
                    >
                        <TileContent>
                            <NumericContent value="4.9" valueColor="Good" withMargin="false" />
                        </TileContent>
                    </GenericTile>
                </HBox>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <VBox>

                <!-- Booking Section -->
                <Panel class="sapUiMediumMargin" expandable="true" expanded="false">
                    <headerToolbar>
                        <Toolbar>
                            <core:Icon src="sap-icon://appointment" color="Default" />
                            <Title text="Book your car" level="H3" />
                            <ToolbarSpacer />
                        </Toolbar>
                    </headerToolbar>
                    <form:SimpleForm
                        editable="true"
                        layout="ResponsiveGridLayout"
                        labelSpanXL="3" labelSpanL="3" labelSpanM="3" labelSpanS="12"
                    >
                        <form:content>
                            <Label text="Car type" />
                            <Select width="100%">
                                <core:Item key="Sedan" text="Sedan" />
                                <core:Item key="SUV" text="SUV" />
                                <core:Item key="Luxury" text="Luxury" />
                            </Select>
                            <Label text="Pickup Location" />
                            <Input placeholder="Enter City..." />
                            <Label text="Date Range" />
                            <DateRangeSelection />
                            <Label text="" />
                            <Button text="Search Available Cars" type="Emphasized" press=".onNavVehicles" width="200px" />
                        </form:content>
                    </form:SimpleForm>
                </Panel>

                <!-- Featured Cars -->
                <VBox class="sapUiMediumMargin">
                    <HBox alignItems="Center" justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                        <Title text="Our Top Recommendations" level="H2" />
                        <Link text="View All" press=".onNavVehicles" />
                    </HBox>

                    <f:GridContainer
                        id="featuredCarsList"
                        items="{path: '/Cars', length: 6}"
                        width="100%"
                    >
                        <f:layout>
                            <f:GridContainerSettings
                                minColumnSize="200px"
                                maxColumnSize="400px"
                                gap="1rem"
                            />
                        </f:layout>
                        <f:items>
                            <Panel
                                width="100%"
                                backgroundDesign="Solid"
                                class="sapUiNoContentPadding"
                            >
                                <VBox width="100%">
                                    <!-- Image with fallback src for cars with no imageURL -->
                                    <Image
                                        src="{= ${imageURL} ? ${imageURL} : 'sap-icon://car-rental'}"
                                        width="100%"
                                        height="180px"
                                        mode="Background"
                                        backgroundSize="cover"
                                        backgroundPosition="center"
                                    />
                                    <VBox class="sapUiSmallMargin">
                                        <HBox justifyContent="SpaceBetween" width="100%" class="sapUiTinyMarginBottom">
                                            <VBox>
                                                <Title text="{brand} {model}" level="H4" wrapping="true" />
                                            </VBox>
                                            <VBox alignItems="End">
                                                <ObjectNumber
                                                    number="{pricePerDay}"
                                                    numberUnit="$ / day"
                                                    emphasized="true"
                                                />
                                            </VBox>
                                        </HBox>
                                        <ObjectStatus
                                            text="{status}"
                                            state="{= ${status} === 'Available' ? 'Success' : 'Error' }"
                                            inverted="true"
                                            class="sapUiSmallMarginBottom"
                                        />
                                        <core:HTML content="&lt;div style='border-top:1px solid #e5e5e5;margin-bottom:8px'/&gt;" />
                                        <HBox justifyContent="SpaceBetween" width="100%" class="sapUiTinyMarginBottom">
                                            <VBox>
                                                <Label text="Year" design="Bold" />
                                                <Text text="{year}" />
                                            </VBox>
                                            <VBox alignItems="End">
                                                <Label text="Fuel" design="Bold" />
                                                <Text text="{fuelType}" />
                                            </VBox>
                                        </HBox>
                                        <HBox justifyContent="SpaceBetween" width="100%" class="sapUiSmallMarginBottom">
                                            <VBox>
                                                <Label text="Transmission" design="Bold" />
                                                <Text text="{transmission}" />
                                            </VBox>
                                            <VBox alignItems="End">
                                                <Label text="Seats" design="Bold" />
                                                <Text text="{seats}" />
                                            </VBox>
                                        </HBox>
                                        <!-- Rent Now calls onRentNow, NOT onViewDetails -->
                                        <Button
                                            text="Rent Now"
                                            type="Emphasized"
                                            width="100%"
                                            press=".onRentNow"
                                            icon="sap-icon://car-rental"
                                            enabled="{= ${status} === 'Available'}"
                                        />
                                    </VBox>
                                </VBox>
                            </Panel>
                        </f:items>
                    </f:GridContainer>
                </VBox>

            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>