<mvc:View
    controllerName="com.moyo.demo.caplugins.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:card="sap.f.cards"
    xmlns:form="sap.ui.layout.form"
>
    <f:DynamicPage
        id="homePage"
        headerExpanded="true"
        showFooter="false"
        fitContent="true"
        class="sapUiNoContentPadding"
    >
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <HBox alignItems="Center">
                        <Title text="Moyotech" class="sapUiSmallMarginEnd" />
                        <Link text="Home" press=".onNavHome" class="sapUiSmallMarginEnd" />
                        <Link text="Vehicles" press=".onNavVehicles" class="sapUiSmallMarginEnd" />
                        <Link text="Details" class="sapUiSmallMarginEnd" />
                    </HBox>
                </f:heading>
                <f:actions>
                    <Button icon="sap-icon://phone" text="+996 247-1680" type="Transparent" />
                    <Button icon="sap-icon://customer" type="Transparent" />
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <HBox
                    justifyContent="Start"
                    alignItems="Center"
                    wrap="Wrap"
                    class="sapUiSmallMarginBegin sapUiTinyMarginTopBottom"
                >
                    <GenericTile
                        header="Fleet Size"
                        subheader="Luxury &amp; Economy"
                        press="onTilePress"
                        sizeBehavior="Small"
                        frameType="TwoByOne"
                        class="sapUiSmallMarginEnd"
                    >
                        <TileContent>
                            <NumericContent value="250+" valueColor="Good" indicator="Up" withMargin="false" />
                        </TileContent>
                    </GenericTile>

                    <GenericTile
                        header="Locations"
                        subheader="Across the Country"
                        press="onTilePress"
                        sizeBehavior="Small"
                        frameType="TwoByOne"
                        class="sapUiSmallMarginEnd"
                    >
                        <TileContent>
                            <NumericContent value="45" valueColor="Neutral" withMargin="false" />
                        </TileContent>
                    </GenericTile>

                    <GenericTile
                        header="Reviews"
                        subheader="Customer Satisfaction"
                        press="onTilePress"
                        sizeBehavior="Small"
                        frameType="TwoByOne"
                    >
                        <TileContent>
                            <NumericContent value="4.9" valueColor="Good" withMargin="false" />
                        </TileContent>
                    </GenericTile>
                </HBox>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <VBox>

                <!-- Booking Section -->
                <Panel class="sapUiMediumMargin" expandable="true" expanded="false">
                    <headerToolbar>
                        <Toolbar>
                            <core:Icon src="sap-icon://appointment" color="Default" />
                            <Title text="Book your car" level="H3" />
                            <ToolbarSpacer />
                        </Toolbar>
                    </headerToolbar>
                    <form:SimpleForm
                        editable="true"
                        layout="ResponsiveGridLayout"
                        labelSpanXL="3" labelSpanL="3" labelSpanM="3" labelSpanS="12"
                    >
                        <form:content>
                            <Label text="Car type" />
                            <Select width="100%">
                                <core:Item key="Sedan" text="Sedan" />
                                <core:Item key="SUV" text="SUV" />
                                <core:Item key="Luxury" text="Luxury" />
                            </Select>

                            <Label text="Pickup Location" />
                            <Input placeholder="Enter City..." />

                            <Label text="Date Range" />
                            <DateRangeSelection />

                            <Label text="" />
                            <Button text="Search Available Cars" type="Emphasized" press=".onNavVehicles" width="200px" />
                        </form:content>
                    </form:SimpleForm>
                </Panel>

                <!-- Featured Cars -->
                <VBox class="sapUiMediumMargin">
                    <HBox alignItems="Center" justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                        <Title text="Our Top Recommendations" level="H2" />
                        <Link text="View All" press=".onNavVehicles" />
                    </HBox>

                    <!--
                        minColumnSize + maxColumnSize is the correct SAP UI5 approach
                        for responsive equal-width columns that fill the full container width.
                        This gives 3 cards per row on large screens, fewer on smaller screens.
                    -->
                    <f:GridContainer
                        id="featuredCarsList"
                        items="{path: '/Cars', length: 6}"
                        width="100%"
                    >
                        <f:layout>
                            <f:GridContainerSettings
                                minColumnSize="300px"
                                maxColumnSize="600px"
                                gap="1rem"
                            />
                        </f:layout>
                        <f:items>
                            <f:Card width="100%">
                                <f:header>
                                    <card:Header
                                        title="{brand} {model}"
                                        subtitle="${pricePerDay} / day"
                                    />
                                </f:header>
                                <f:content>
                                    <VBox class="sapUiSmallMargin">
                                        <ObjectStatus
                                            text="{status}"
                                            state="{= ${status} === 'Available' ? 'Success' : 'Error' }"
                                            inverted="true"
                                            class="sapUiTinyMarginBottom"
                                        />
                                        <Image
                                            src="{imageURL}"
                                            width="100%"
                                            height="160px"
                                            mode="Background"
                                            backgroundSize="cover"
                                            backgroundPosition="center"
                                            class="sapUiSmallMarginTopBottom"
                                        />
                                        <HBox justifyContent="SpaceBetween" class="sapUiTinyMarginBottom">
                                            <ObjectAttribute title="Year" text="{year}" />
                                            <ObjectAttribute title="Fuel" text="{fuelType}" />
                                        </HBox>
                                        <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                                            <ObjectAttribute title="Gear" text="{transmission}" />
                                            <ObjectAttribute title="Seats" text="{seats}" />
                                        </HBox>
                                        <Button text="Rent Now" type="Emphasized" width="100%" press=".onViewDetails" />
                                    </VBox>
                                </f:content>
                            </f:Card>
                        </f:items>
                    </f:GridContainer>
                </VBox>

            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>