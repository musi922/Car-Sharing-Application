<mvc:View
    controllerName="com.moyo.demo.caplugins.controller.Details"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.f"
    xmlns:uxap="sap.uxap"
>
    <uxap:ObjectPageLayout id="objectPageLayout" showTitleInHeaderContent="true" alwaysShowContentHeader="false" preserveHeaderStateOnScroll="false" headerDesign="Light" isChildPage="true">
        <uxap:headerTitle>
            <uxap:ObjectPageHeader 
                objectTitle="{brand} {model}" 
                objectSubtitle="{year} - {fuelType}" 
                isObjectIconAlwaysVisible="false" 
                isObjectTitleAlwaysVisible="true" 
                isObjectSubtitleAlwaysVisible="true" 
                showPlaceholder="true"
                showNavButton="true"
                navButtonPress=".onNavBack">
                <uxap:actions>
                    <Button text="Rent this vehicle" type="Emphasized" press=".onRentPress" />
                </uxap:actions>
            </uxap:ObjectPageHeader>
        </uxap:headerTitle>

        <uxap:headerContent>
            <FlexBox wrap="Wrap" alignItems="Start">
                <VBox class="sapUiSmallMarginEnd">
                    <Title text="${pricePerDay}" level="H1" color="Critical" />
                    <Text text="per day" />
                </VBox>
                <VBox class="sapUiSmallMarginEnd">
                    <Label text="Status" />
                    <ObjectStatus 
                        text="{status}" 
                        state="{= ${status} === 'Available' ? 'Success' : 'Error' }" 
                        inverted="true" />
                </VBox>
                <VBox>
                    <Label text="Seats" />
                    <Text text="{seats}" />
                </VBox>
            </FlexBox>
        </uxap:headerContent>

        <uxap:sections>
            <uxap:ObjectPageSection title="Overview">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <VBox>
                            <Image src="{imageURL}" width="100%" height="400px" mode="Background" backgroundSize="contain" />
                            <Title text="Description" level="H3" class="sapUiMediumMarginTopBottom" />
                            <Text text="{description}" />
                        </VBox>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <uxap:ObjectPageSection title="Technical Details">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <l:Grid containerQuery="true" defaultSpan="XL3 L4 M6 S12">
                            <GenericTile header="Max Speed" subheader="{maxSpeed} km/h" press=".onTilePress">
                                <TileContent>
                                    <core:Icon src="sap-icon://speed" size="2rem" color="Default" />
                                </TileContent>
                            </GenericTile>
                            <GenericTile header="Engine Type" subheader="{engineType}" press=".onTilePress">
                                <TileContent>
                                    <core:Icon src="sap-icon://settings" size="2rem" color="Default" />
                                </TileContent>
                            </GenericTile>
                            <GenericTile header="Fuel Consumption" subheader="{fuelConsumption} L/100km" press=".onTilePress">
                                <TileContent>
                                    <core:Icon src="sap-icon://pipeline-medicine" size="2rem" color="Default" />
                                </TileContent>
                            </GenericTile>
                        </l:Grid>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
        </uxap:sections>
    </uxap:ObjectPageLayout>
</mvc:View>
